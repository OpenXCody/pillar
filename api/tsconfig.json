{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "paths": {
      "@shared/*": ["../shared/*"],
      "@server/*": ["../server/*"]
    },
    "baseUrl": "."
  },
  "include": ["*.ts", "../server/**/*.ts", "../shared/**/*.ts"]
}
